{
    "main": "main.js",
    "name": "scriptum",
    "productName": "Scriptum",
    "version": "0.7.0",
    "description": "Personal reading and library management tool",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "electron": "^38.0.0",
        "electron-builder": "^26.0.12"
    },
    "scripts": {
        "start": "electron .",
        "build": "electron-builder",
        "build-win": "electron-builder --win",
        "dist": "electron-builder --publish=never"
    },
    "build": {
        "compression": "maximum",
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "appId": "com.sparsile.scriptum",
        "productName": "Scriptum",
        "directories": {
            "output": "dist"
        },
        "files": [
            "src/**/*",
            "main.js",
            "preload.js",
            "package.json",
            "!src/node_modules",
            "!**/*.map"
        ],
        "win": {
            "target": "nsis",
            "icon": "assets/scriptum.ico"
        }
    }
}
