{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Scriptum",
    "version": "0.1.0",
    "identifier": "com.scriptum.app",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Scriptum",
                "width": 1700,
                "height": 1700,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "android": {
            "debugApplicationIdSuffix": ".debug"
        }
    }
}
